module multiplier(
input clk,
input signed [15:0] A,
input signed [15:0] B,
output reg signed [31:0] P
);
reg signed [15:0] A_reg, B_reg;
always @(posedge clk) begin
A_reg <= A;
B_reg <= B;
P <= A_reg * B_reg;
end
endmodule

module multiplier_bit(
input  signed [15:0] A,  
input  signed [15:0] B,   
output signed [31:0] P    
);
assign P = A * B;
endmodule

.A(A),
.B(B),
.P(P)
);
initial
 begin
$monitor("Time=%0t | A=%b B=%b | P=%b",$time, A, B, P);
A = 1; B = 1; #10;   
A = 2; B = 3; #10;   
A = 3; B = 4; #10; 
A = 5; B = 2; #10;   
A = 6; B = 3; #10;  
A = 7; B = 2; #10;  
A = 8; B = 3; #10;  
A = 9; B = 2; #10;   
$finish;
end
endmodule
